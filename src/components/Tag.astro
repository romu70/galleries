---
const { tag } = Astro.props;
---

<div class="tag" data-tag={tag}>{tag}</div>

<style>
  .tag {
    padding: 0.15rem 0.5rem;
    background-color: var(--main-color);
    opacity: 0.7;
    font-size: 0.75rem;
    font-weight: 500;
    border-radius: 0.25rem;
    margin-bottom: auto;
    white-space: nowrap;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .tag:hover,
  .tag.active {
    opacity: 1;
    outline: 2px solid var(--main-color);
    outline-offset: 2px;
  }
</style>

